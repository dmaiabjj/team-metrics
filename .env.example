# Azure DevOps – required for /report
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PAT=your-personal-access-token

# Optional: project override (teams.yaml usually defines project per team)
# AZURE_DEVOPS_PROJECT=

# Optional: cache tuning (defaults shown)
# CACHE_TTL_SECONDS=0
# AZURE_CACHE_MAX=2048
# AZURE_CACHE_TTL_SECONDS=300
# DEPLOYMENT_CACHE_MAX=512
# DEPLOYMENT_CACHE_TTL_SECONDS=3600
