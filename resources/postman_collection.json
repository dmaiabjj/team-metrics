{
  "info": {
    "name": "Azure DevOps Performance Report API",
    "description": "Performance report endpoints for team deliverables and date range. Each deliverable includes tags, has_rework, is_spillover, bounces, bounce_details, is_technical_debt, is_post_mortem, post_mortem_sla_met, and delivery_days. Includes cache management endpoints for manual invalidation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "team_id",
      "value": "game-services"
    },
    {
      "key": "team_ids",
      "value": "game-services,payment-services"
    },
    {
      "key": "start_date",
      "value": "2025-01-01"
    },
    {
      "key": "end_date",
      "value": "2025-01-31"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Health check. No auth or params."
      }
    },
    {
      "name": "Report (single team)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/report?team_id={{team_id}}&start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["report"],
          "query": [
            {
              "key": "team_id",
              "value": "{{team_id}}",
              "description": "Team slug, e.g. game-services"
            },
            {
              "key": "start_date",
              "value": "{{start_date}}",
              "description": "Start of period (ISO date)"
            },
            {
              "key": "end_date",
              "value": "{{end_date}}",
              "description": "End of period (ISO date)"
            }
          ]
        },
        "description": "Get performance report for one team and date range. Returns deliverables with description, status timeline, period boundary statuses, hierarchy, linked bugs/tasks, role assignments (developer, qa, release_manager), tags (Code Defect, Scope / Requirements, Spillover), and has_rework."
      }
    },
    {
      "name": "Report (multiple teams)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/report/multi?team_ids={{team_ids}}&start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["report", "multi"],
          "query": [
            {
              "key": "team_ids",
              "value": "{{team_ids}}",
              "description": "Comma-separated team slugs"
            },
            {
              "key": "start_date",
              "value": "{{start_date}}",
              "description": "Start of period (ISO date)"
            },
            {
              "key": "end_date",
              "value": "{{end_date}}",
              "description": "End of period (ISO date)"
            }
          ]
        },
        "description": "Get performance report for multiple teams. Returns { teams: [ { team_id, deliverables }, ... ] }. Each deliverable includes description, status timeline, period boundary statuses, role assignments, tags (Code Defect, Scope / Requirements, Spillover), and has_rework."
      }
    },
    {
      "name": "KPI - Single Team",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/kpi?team_id={{team_id}}&start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["kpi"],
          "query": [
            {"key": "team_id", "value": "{{team_id}}", "description": "Team slug"},
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Compute KPIs for one team. Returns rework rate and delivery predictability with RAG status, breakdown figures, and configurable thresholds."
      }
    },
    {
      "name": "KPI - Summary (all teams)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/kpi/summary?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["kpi", "summary"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Compute KPIs for all configured teams. Returns per-KPI averages (rework rate, delivery predictability) across teams and each team's individual breakdown."
      }
    },
    {
      "name": "KPI - Drilldown",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/kpi/drilldown?team_id={{team_id}}&start_date={{start_date}}&end_date={{end_date}}&metric=items_with_rework",
          "host": ["{{base_url}}"],
          "path": ["kpi", "drilldown"],
          "query": [
            {"key": "team_id", "value": "{{team_id}}", "description": "Team slug"},
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "metric", "value": "items_with_rework", "description": "Metric to drill into: items_reached_qa, items_with_rework, items_bounced_back, items_with_bugs, items_committed, items_deployed, items_started_in_period, items_spillover"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items to return (1-500)"}
          ]
        },
        "description": "Return full DeliverableRow objects filtered to items behind a specific KPI metric. Supports skip/limit pagination."
      }
    },
    {
      "name": "KPI - Drilldown (Delivery Predictability)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/kpi/drilldown?team_id={{team_id}}&start_date={{start_date}}&end_date={{end_date}}&metric=items_deployed",
          "host": ["{{base_url}}"],
          "path": ["kpi", "drilldown"],
          "query": [
            {"key": "team_id", "value": "{{team_id}}", "description": "Team slug"},
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "metric", "value": "items_deployed", "description": "Delivery Predictability metric: items_committed, items_deployed, items_started_in_period, items_spillover"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items to return (1-500)"}
          ]
        },
        "description": "Return full DeliverableRow objects for a Delivery Predictability metric. Supports skip/limit pagination."
      }
    },
    {
      "name": "Cache - Invalidate All",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache",
          "host": ["{{base_url}}"],
          "path": ["cache"]
        },
        "description": "Clear all cached data (L1 report cache + L2 work-item cache). Returns counts of cleared entries."
      }
    },
    {
      "name": "Cache - Invalidate Team",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache/{{team_id}}",
          "host": ["{{base_url}}"],
          "path": ["cache", "{{team_id}}"]
        },
        "description": "Clear cached reports for a specific team. L2 work-item cache is unaffected."
      }
    },
    {
      "name": "Cache - Stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache/stats",
          "host": ["{{base_url}}"],
          "path": ["cache", "stats"]
        },
        "description": "Return current cache sizes (report entries and work-item entries)."
      }
    }
  ]
}
