{
  "info": {
    "name": "Azure DevOps Team Metrics API",
    "description": "Dashboard, team KPIs, drilldown, and work-item endpoints for Azure DevOps performance reporting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000"},
    {"key": "team_id", "value": "game-services"},
    {"key": "start_date", "value": "2026-03-09"},
    {"key": "end_date", "value": "2026-03-09"}
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Health check. No auth or params."
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/dashboard?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["dashboard"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Cross-team KPI averages and per-team breakdown."
      }
    },
    {
      "name": "Team KPIs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "All KPIs for one team."
      }
    },
    {
      "name": "Team KPI Detail - Rework Rate",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/rework-rate?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "rework-rate"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Rework Rate detail with breakdown metrics for one team."
      }
    },
    {
      "name": "Team KPI Detail - Delivery Predictability",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/delivery-predictability?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "delivery-predictability"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Delivery Predictability detail with breakdown metrics for one team."
      }
    },
    {
      "name": "Team KPI Detail - Flow Hygiene",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/flow-hygiene?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "flow-hygiene"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "Flow Hygiene detail with per-state breakdown, WIP limits, and queue load for one team."
      }
    },
    {
      "name": "Drilldown - Rework Rate / items_reached_qa",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/rework-rate/drilldown/items_reached_qa?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "rework-rate", "drilldown", "items_reached_qa"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Deliverables that reached QA Active at any point."
      }
    },
    {
      "name": "Drilldown - Rework Rate / items_with_rework",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/rework-rate/drilldown/items_with_rework?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "rework-rate", "drilldown", "items_with_rework"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "QA items with rework tags (Code Defect or Scope/Requirements)."
      }
    },
    {
      "name": "Drilldown - Rework Rate / items_bounced_back",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/rework-rate/drilldown/items_bounced_back?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "rework-rate", "drilldown", "items_bounced_back"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Deliverables with bounces > 0 (returned from QA/Delivered to active)."
      }
    },
    {
      "name": "Drilldown - Rework Rate / items_with_bugs",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/rework-rate/drilldown/items_with_bugs?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "rework-rate", "drilldown", "items_with_bugs"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Deliverables with at least one linked child bug."
      }
    },
    {
      "name": "Drilldown - Delivery Predictability / items_committed",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/delivery-predictability/drilldown/items_committed?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "delivery-predictability", "drilldown", "items_committed"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Items committed to the period (started in period + spillovers)."
      }
    },
    {
      "name": "Drilldown - Delivery Predictability / items_deployed",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/delivery-predictability/drilldown/items_deployed?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "delivery-predictability", "drilldown", "items_deployed"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Committed items that ended the period in Delivered status."
      }
    },
    {
      "name": "Drilldown - Delivery Predictability / items_started_in_period",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/delivery-predictability/drilldown/items_started_in_period?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "delivery-predictability", "drilldown", "items_started_in_period"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Items whose start_date falls within the period (non-spillovers)."
      }
    },
    {
      "name": "Drilldown - Delivery Predictability / items_spillover",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/delivery-predictability/drilldown/items_spillover?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "delivery-predictability", "drilldown", "items_spillover"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Items that were already active before the period (spillovers)."
      }
    },
    {
      "name": "Drilldown - Flow Hygiene / items_in_queue",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/flow-hygiene/drilldown/items_in_queue?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "flow-hygiene", "drilldown", "items_in_queue"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Deliverables that spent time in any configured queue state during the period."
      }
    },
    {
      "name": "Work Items",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/work-items?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "work-items"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "skip", "value": "0", "description": "Pagination offset"},
            {"key": "limit", "value": "100", "description": "Max items (1-500)"}
          ]
        },
        "description": "Paginated work items for one team. Returns deliverables with full metadata."
      }
    },
    {
      "name": "Team KPI Detail - WIP Discipline",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/wip-discipline?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "wip-discipline"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"}
          ]
        },
        "description": "WIP Discipline KPI detail with per-developer/QA breakdown and status breakdown."
      }
    },
    {
      "name": "Drilldown - WIP Discipline / developer_assignments",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/wip-discipline/drilldown/developer_assignments?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "wip-discipline", "drilldown", "developer_assignments"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "person", "value": "", "description": "Optional: filter to a specific person", "disabled": true}
          ]
        },
        "description": "Drilldown into developer assignments. Optionally filter by person name."
      }
    },
    {
      "name": "Drilldown - WIP Discipline / qa_assignments",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/teams/{{team_id}}/kpis/wip-discipline/drilldown/qa_assignments?start_date={{start_date}}&end_date={{end_date}}",
          "host": ["{{base_url}}"],
          "path": ["teams", "{{team_id}}", "kpis", "wip-discipline", "drilldown", "qa_assignments"],
          "query": [
            {"key": "start_date", "value": "{{start_date}}", "description": "Start of period (ISO date)"},
            {"key": "end_date", "value": "{{end_date}}", "description": "End of period (ISO date)"},
            {"key": "person", "value": "", "description": "Optional: filter to a specific QA", "disabled": true}
          ]
        },
        "description": "Drilldown into QA assignments. Optionally filter by person name."
      }
    },
    {
      "name": "Cache - Invalidate All",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache",
          "host": ["{{base_url}}"],
          "path": ["cache"]
        },
        "description": "Clear all cached data (L1 report cache + L2 work-item cache)."
      }
    },
    {
      "name": "Cache - Invalidate Team",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache/{{team_id}}",
          "host": ["{{base_url}}"],
          "path": ["cache", "{{team_id}}"]
        },
        "description": "Clear cached reports for a specific team."
      }
    },
    {
      "name": "Cache - Stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/cache/stats",
          "host": ["{{base_url}}"],
          "path": ["cache", "stats"]
        },
        "description": "Return current cache sizes."
      }
    }
  ]
}
